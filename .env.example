# ---- Общее ----
ENVIRONMENT=dev                        # dev|prod
LOG_LEVEL=INFO

# ---- Backend ----
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DATABASE_URL=postgresql+asyncpg://vpn:vpn@postgres:5432/vpn_shop
# Для локальной разработки без Postgres:
# DATABASE_URL=sqlite+aiosqlite:///./dev.db
BOT_API_TOKEN=change-me-bot-to-backend-shared-secret
ADMIN_API_TOKEN=change-me-admin-secret

# ---- Telegram bot ----
BOT_TOKEN=123456:ABC-your-bot-token
BACKEND_URL=http://backend:8000
BOT_ADMIN_IDS=123456789                # через запятую
DEFAULT_LOCALE=ru

# ---- 3x-ui ----
# ВАЖНО: только схема + хост (+порт). Без URI Path панели.
# Правильно:   https://panel.example.com:2053
# Неправильно: https://panel.example.com:2053/secretpath
# URI Path в панели нужно отключить (Panel Settings → Basic → URI Path = пусто),
# иначе API x-ui не работает.
XUI_HOST=https://your-panel.example.com
XUI_USERNAME=admin
XUI_PASSWORD=admin
# ID инбаунда для выдачи VLESS клиентов.
# Рекомендуется отдельный обычный VLESS TCP инбаунд (без Reality) для стабильности
# API, например ID=2. Reality-инбаунд поддерживается (flow=xtls-rprx-vision
# подставится автоматически), но чаще ломается при ошибках в настройках.
XUI_INBOUND_ID=2
XUI_USE_TLS_VERIFY=true
# Базовый URL подписки панели (если включён sub listener). Пусто — в ответах
# будет только vless_link и QR без subscription_url.
XUI_SUB_BASE_URL=

# ---- Платежи: YooKassa ----
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=https://t.me/your_bot

# ---- Платежи: CryptoBot ----
CRYPTOBOT_TOKEN=
CRYPTOBOT_NETWORK=mainnet              # mainnet|testnet
