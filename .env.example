# ---- Общее ----
ENVIRONMENT=dev                        # dev|prod
LOG_LEVEL=INFO

# ---- Backend ----
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DATABASE_URL=postgresql+asyncpg://vpn:vpn@postgres:5432/vpn_shop
# Для локальной разработки без Postgres:
# DATABASE_URL=sqlite+aiosqlite:///./dev.db
BOT_API_TOKEN=change-me-bot-to-backend-shared-secret
ADMIN_API_TOKEN=change-me-admin-secret

# ---- Telegram bot ----
BOT_TOKEN=123456:ABC-your-bot-token
BACKEND_URL=http://backend:8000
BOT_ADMIN_IDS=123456789                # через запятую
DEFAULT_LOCALE=ru

# ---- Public subscription URL (multi-server) ----
# Базовый URL для публичного эндпоинта GET /sub/{sub_token}.
# Бот вставит его в IssuedVpnOut.subscription_url, Happ откроет
# happ://import-sub?url=<...>/sub/<token>. Пусто — поле будет null.
PUBLIC_SUB_BASE_URL=http://1.2.3.4:8000

# ---- Trial (one-tap «🚀 Попробовать бесплатно») ----
TRIAL_DURATION_HOURS=24
TRIAL_TRAFFIC_GB=10

# ---- 3x-ui (LEGACY single-server fallback) ----
# Начиная с миграции 0003 настройки x-ui хранятся в таблице ``servers`` и
# управляются через POST /api/v1/admin/servers. Переменные ниже используются
# ТОЛЬКО для бэкфилла существующих инсталляций (миграция 0003 один раз
# создаст из них запись в таблице ``servers``). Новые инсталляции могут
# оставить их пустыми и добавлять серверы напрямую через админ API.
#
# ВАЖНО: только схема + хост (+порт). Без URI Path панели.
# Правильно:   https://panel.example.com:2053
# Неправильно: https://panel.example.com:2053/secretpath
# URI Path в панели нужно отключить (Panel Settings → Basic → URI Path = пусто).
XUI_HOST=https://your-panel.example.com
XUI_USERNAME=admin
XUI_PASSWORD=admin
XUI_INBOUND_ID=2
XUI_USE_TLS_VERIFY=true
XUI_SUB_BASE_URL=

# ---- Платежи: YooKassa ----
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=https://t.me/your_bot

# ---- Платежи: CryptoBot ----
CRYPTOBOT_TOKEN=
CRYPTOBOT_NETWORK=mainnet              # mainnet|testnet
